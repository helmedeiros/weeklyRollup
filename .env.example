# Copy this file to .env and fill in the values for your setup. The .env is
# gitignored; it never leaves your machine.

# ---------------------------------------------------------------------------
# Google Sheets integration
# ---------------------------------------------------------------------------
# Full MCP URL of a hosted Google Drive MCP server that speaks the
# @modelcontextprotocol JSON-RPC over HTTP. The runner reaches it through
# `npx -y mcp-remote <url>`, which handles the OAuth handshake against the
# server on first use (browser flow) and caches tokens under ~/.mcp-auth/
# for every subsequent run.
GOOGLE_SHEETS_MCP_URL=

# ---------------------------------------------------------------------------
# Jira MCP (see jira-mcp/.env.example for the fields inside that folder)
# ---------------------------------------------------------------------------
# JIRA_MCP_DIR is auto-detected when the bundled jira-mcp/ folder exists.
