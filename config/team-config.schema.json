{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mission Weekly Rollup Team Config",
  "type": "object",
  "required": ["team", "jira", "weekly_update", "sheet", "email"],
  "additionalProperties": false,
  "properties": {
    "team": {
      "type": "object",
      "required": ["id", "name", "timezone"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "timezone": { "type": "string", "minLength": 1 }
      }
    },
    "jira": {
      "type": "object",
      "required": ["base_url", "epic_issue_type", "mission_label_pattern", "fields"],
      "additionalProperties": false,
      "properties": {
        "base_url": { "type": "string", "minLength": 1 },
        "board_id": { "type": "string" },
        "project_key": { "type": "string" },
        "epic_issue_type": { "type": "string", "default": "Epic" },
        "mission_label_pattern": { "type": "string", "default": "mission-{month}-{year}" },
        "fields": {
          "type": "object",
          "required": ["dri", "due_date", "linked_okr", "progress", "status"],
          "additionalProperties": false,
          "properties": {
            "dri": { "$ref": "#/$defs/field" },
            "due_date": { "$ref": "#/$defs/field" },
            "linked_okr": { "$ref": "#/$defs/field" },
            "progress": { "$ref": "#/$defs/field" },
            "status": { "$ref": "#/$defs/field" }
          }
        },
        "done_statuses": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "weekly_update": {
      "type": "object",
      "required": ["window", "validation"],
      "additionalProperties": false,
      "properties": {
        "cover_authors": {
          "type": "array",
          "description": "Emails allowed to write weekly mission updates on behalf of the DRI (e.g. EM cover when the DRI is out). Matched case-insensitively against comment.author.emailAddress.",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true,
          "default": []
        },
        "window": {
          "type": "object",
          "required": ["start_day", "start_time", "cutoff_day", "cutoff_time"],
          "additionalProperties": false,
          "properties": {
            "start_day": { "type": "string" },
            "start_time": { "type": "string" },
            "cutoff_day": { "type": "string" },
            "cutoff_time": { "type": "string" }
          }
        },
        "validation": {
          "type": "object",
          "required": [
            "require_template_match",
            "minimum_score",
            "allow_section_aliases",
            "allow_unstructured_if_confident",
            "no_update_red_after_weeks"
          ],
          "additionalProperties": false,
          "properties": {
            "require_template_match": { "type": "boolean" },
            "minimum_score": { "type": "integer", "minimum": 1 },
            "optional_sections": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["blockers"]
              },
              "uniqueItems": true
            },
            "allow_section_aliases": { "type": "boolean" },
            "allow_unstructured_if_confident": { "type": "boolean" },
            "no_update_red_after_weeks": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "previous_month_spillover": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "include_if_status_not_in_done_statuses": { "type": "boolean", "default": true }
      }
    },
    "hygiene": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "severity_overrides": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": ["red", "yellow", "info"]
          }
        }
      }
    },
    "run_history": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "tab_name": {
          "type": "string",
          "minLength": 1,
          "default": "_Run History"
        }
      }
    },
    "sheet": {
      "type": "object",
      "required": ["folder_id", "tab_name_pattern", "create_tab_if_missing", "mode"],
      "additionalProperties": false,
      "properties": {
        "folder_id": {
          "type": "string",
          "minLength": 1,
          "description": "Google Drive folder that owns every team's rollup spreadsheet. Set this to the shared folder for your organisation. Runtime enforcement of a specific id is optional via WEEKLY_ROLLUP_REQUIRED_FOLDER_ID."
        },
        "file_name_pattern": {
          "type": "string",
          "default": "{team_name} - Mission Execution Updates"
        },
        "url": {
          "type": "string",
          "description": "Optional resolved Google Sheet URL for local runs; do not commit real team Sheet URLs."
        },
        "spreadsheet_url": {
          "type": "string",
          "description": "Optional alias for the resolved Google Sheet URL; do not commit real team Sheet URLs."
        },
        "resolved_spreadsheet_id": {
          "type": "string",
          "description": "Optional resolved Google Sheet ID for local runs; do not commit real team Sheet IDs."
        },
        "tab_name_pattern": { "type": "string", "default": "Week {iso_week}" },
        "create_tab_if_missing": { "type": "boolean" },
        "mode": { "type": "string", "enum": ["replace_week_tab"] }
      }
    },
    "email": {
      "type": "object",
      "required": ["create_draft_only", "to", "subject_pattern"],
      "additionalProperties": false,
      "properties": {
        "create_draft_only": { "type": "boolean", "const": true },
        "to": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "default": ["missions@example.com"]
        },
        "from_address": { "type": "string" },
        "cc": {
          "type": "array",
          "items": { "type": "string" }
        },
        "bcc": {
          "type": "array",
          "items": { "type": "string" }
        },
        "subject_pattern": { "type": "string" },
        "preview_to": { "type": "string" },
        "greeting": { "type": "string" },
        "signoff": { "type": "string" },
        "signoff_name": { "type": "string" }
      }
    }
  },
  "$defs": {
    "field": {
      "type": "object",
      "required": ["field_id"],
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string" },
        "property_key": { "type": "string" },
        "path": { "type": "string" },
        "field_id": { "type": "string" }
      }
    }
  }
}
