.env
.tokens/
output/
__pycache__/
*.pyc

# Local team configs can contain real email addresses and team-specific values.
config/delivery_*.yaml
config/*local*.yaml
.DS_Store

# Real per-team weekly snapshots may reference internal identifiers,
# objective keys, employee names, or historical scoring. Keep them local;
# the public/demo dashboard is fed from demo-snapshots/ instead.
snapshots/**/*.json
snapshots/_aggregates/
snapshots/_dashboards/

# Rendered dashboards are build artifacts: CI renders and deploys them to
# GitHub Pages (see .github/workflows/pages.yml). Never commit the output.
# Source of truth is demo-snapshots/*.json + templates/dashboard.html.
demo-snapshots/_dashboards/
docs/index.html
docs/email/
/public/
