# -----------------------------------------------------------------------------
# Google OAuth Credentials
# -----------------------------------------------------------------------------
# Create at Google Cloud Console: https://console.cloud.google.com/
#   - Create a new project (e.g. weeklyRollup)
#   - Enable the Google Drive API and Google Sheets API
#   - OAuth consent screen -> External -> add yourself as a test user
#     Requested scopes: /auth/drive.file and /auth/spreadsheets are enough
#   - Credentials -> Create OAuth client ID -> Desktop app -> download JSON
# Paste the values from the downloaded JSON below.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Loopback redirect used by the OAuth Desktop-app flow. Any free port works; the
# auth script starts a one-shot local HTTP listener on it during the browser
# consent step.
OAUTH_REDIRECT_HOST=127.0.0.1
OAUTH_REDIRECT_PORT=3003
